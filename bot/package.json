{
  "name": "bot-telegram",
  "version": "1.0.0",
  "description": "Bot de Telegram que registra compras e gastos pessoais a partir de texto ou cupons fiscais, usando IA (Gemini/GPT) e OCR (Google Vision), com persistência em MongoDB.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --ext ts --exec ts-node -P tsconfig.json src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "migrate:canonical": "ts-node -P tsconfig.json src/scripts/migrateCanonical.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts --config ./eslint.config.mjs",
    "lint:fix": "eslint . --ext .ts --fix --config ./eslint.config.mjs",
    "prettier": "prettier --write .",
    "prepare": "cd .. && husky bot/.husky"
  },
  "keywords": [
    "telegram",
    "bot",
    "telegraf",
    "finance",
    "expenses",
    "ocr",
    "ai",
    "gemini",
    "gpt",
    "mongodb"
  ],
  "author": "Yves",
  "license": "ISC",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google-cloud/vertexai": "1.9.3",
    "@google-cloud/vision": "^4.3.2",
    "@whiskeysockets/baileys": "6.7.23",
    "@workos-inc/node": "^10.2.0",
    "dotenv": "^16.4.7",
    "inversify": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.10.1",
    "openai": "^4.86.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "telegraf": "^4.16.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/sinon": "^17.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.2",
    "sinon": "^19.0.2",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
