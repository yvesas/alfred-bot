# URL do WebSocket do bot (WebAdapter). Default: ws://localhost:3100
VITE_WS_URL=ws://localhost:3100

# URL do servidor de login do bot (AuthServer). Default: http://localhost:3001
# Usado pelo botão "Entrar" (WorkOS). Deixe vazio/igual se não usar login.
VITE_AUTH_URL=http://localhost:3001

# Mostra o botão "Vincular WhatsApp" (Fase 6). Deixe "false" enquanto não houver número de bot.
VITE_WHATSAPP_ENABLED=false
