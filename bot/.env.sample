DATABASE_URL=
TELEGRAM_TOKEN=

GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

OPENAI_API_KEY=

# Plataformas de mensagem ativas (separadas por vírgula): telegram | whatsapp | web
PLATFORMS=telegram

# WhatsApp (Baileys, não-oficial): diretório da sessão (login por QR). Persistir em volume no Docker.
WHATSAPP_SESSION_DIR=./.wa-session

# Chat web (WebSocket): porta do servidor e origens permitidas (CSV ou "*").
WEB_PORT=3100
WEB_ALLOWED_ORIGIN=*

# Provedor de OCR para fotos de cupom: "gemini" (padrão, multimodal), "vision" (Google)
# ou "paddle" (self-host via microserviço ../ocr-service).
OCR_PROVIDER=gemini

# Usado quando OCR_PROVIDER=paddle (rede interna do docker-compose).
PADDLE_OCR_URL=http://ocr:8000

# Como processar a foto: "ocr" (padrão: OCR → texto → extração) ou
# "multimodal" (imagem → JSON numa única chamada ao modelo). Requer modelo multimodal (gemini).
OCR_MODE=ocr

# Porta do servidor de health/metrics (liveness /health, readiness /ready, /metrics).
HEALTH_PORT=3000

# Nível de log (pino): trace|debug|info|warn|error. Default: info (prod) / debug (dev).
LOG_LEVEL=

# Rate limiting por usuário (mensagens por janela).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Pedir confirmação ("sim/não") antes de salvar uma compra. "false" salva direto.
CONFIRM_PURCHASE=true

# Lembretes (push recorrente: contas a pagar etc.). "false" desliga o agendador.
REMINDERS_ENABLED=true
# Intervalo de verificação de lembretes vencidos, em ms (padrão 60000 = 1 min).
REMINDER_INTERVAL_MS=60000

# --- Login web (WorkOS Magic Auth, telas próprias de e-mail + OTP) — opcional ---
# Login HABILITA com estas 3: WORKOS_API_KEY + WORKOS_CLIENT_ID + JWT_SECRET. Sem elas o login
# fica DESLIGADO e o chat web segue anônimo. Habilite "Magic Auth" no WorkOS Dashboard.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Segredo para assinar o JWT de sessão (qualquer string longa e aleatória — ex.: openssl rand -hex 32).
JWT_SECRET=
# Origem do app web — usada no CORS das chamadas de login e no fluxo hospedado opcional.
WEB_APP_URL=http://localhost:8081
# Porta do servidor HTTP de auth (login/OTP, vínculo).
AUTH_PORT=3001
# OPCIONAL — só para o fluxo hospedado/social legado do AuthKit (não é usado pelo e-mail+OTP).
# Se for usar, cadastre esta URL EXATA no WorkOS Dashboard → Redirects.
WORKOS_REDIRECT_URI=

# --- Vínculo de contas por deep-link (Fase 6) ---
# Username do bot do Telegram (sem @) — usado em https://t.me/<username>?start=<token>.
TELEGRAM_BOT_USERNAME=
# Número do bot no WhatsApp (só dígitos, com DDI) — usado em https://wa.me/<numero>?text=...
# Deixe vazio enquanto não tiver um número; o botão "Vincular WhatsApp" fica indisponível.
WHATSAPP_BOT_NUMBER=