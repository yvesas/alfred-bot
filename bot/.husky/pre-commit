# Monorepo (hooks rodam a partir da raiz do repo). Roda lint+typecheck por projeto,
# só quando há arquivos staged naquele projeto.

changed() { git diff --cached --name-only --diff-filter=ACMR | grep -q "^$1/"; }

if changed bot; then
  ( cd bot && pnpm lint-staged && pnpm typecheck ) || exit 1
fi

if changed web; then
  ( cd web && pnpm lint-staged && pnpm typecheck ) || exit 1
fi
